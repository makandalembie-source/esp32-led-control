<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>LED ESP32</title>
    <style>
        body {
            font-family: Arial;
            text-align: center;
            margin-top: 100px;
            background: #1a1a2e;
            color: white;
        }
        button {
            font-size: 30px;
            padding: 20px 40px;
            margin: 20px;
            border: none;
            border-radius: 15px;
            cursor: pointer;
        }
        .on { background-color: #00ff00; color: black; }
        .off { background-color: #ff4444; color: white; }
        input {
            padding: 10px;
            font-size: 16px;
            width: 200px;
            margin: 20px;
        }
    </style>
</head>
<body>
    <h1>💡 Contrôle LED ESP32</h1>
    
    <div>
        <input type="text" id="espIP" placeholder="IP de l'ESP32">
        <button onclick="connecter()">Connecter</button>
    </div>
    
    <div id="controles" style="display: none;">
        <button class="on" onclick="commander('allumer')">ALLUMER</button>
        <button class="off" onclick="commander('eteindre')">ETEINDRE</button>
        <p id="statut">Statut: ---</p>
    </div>

    <script>
        let espIP = "";

        function connecter() {
            espIP = document.getElementById('espIP').value;
            if(espIP) {
                document.getElementById('controles').style.display = 'block';
                verifierStatut();
            }
        }

        function commander(action) {
            fetch(`http://${espIP}/${action}`)
                .then(() => verifierStatut())
                .catch(() => alert("Erreur"));
        }

        function verifierStatut() {
            fetch(`http://${espIP}/statut`)
                .then(response => response.text())
                .then(statut => {
                    document.getElementById('statut').innerHTML = `Statut: ${statut === 'ON' ? '🟢 ALLUMÉE' : '🔴 ÉTEINTE'}`;
                })
                .catch(() => {});
        }
        
        setInterval(verifierStatut, 2000);
    </script>
</body>
</html>
